function wepBoost(n, d)
{
   if(user.weapon.name == n or user.hat.name == n or user.armor.name == n)
   {
      trace("Weapon boosts skill\'s power by x" + (d + 1));
      return d + 1;
   }
   return 1;
}
function gunspell(a, b)
{
   autoSpell(a,b);
}
function autoSpell(p, d)
{
   trace(d);
   ASpow = d;
   user.noStat = false;
   a = 0;
   while(a < user.weapon.level)
   {
      s = user.weapon.specials[a];
      if(s.substring(0,4) == "cast")
      {
         sp = s.substring(4,s.length);
         if(Math.random() < p)
         {
            _parent.magicGraphics.ASpow = ASpow;
            _parent.magicGraphics.gotoAndPlay(sp);
            _parent.magicGraphics.busy = true;
         }
      }
      a++;
   }
}
function buffAll(b, p)
{
   if(!_parent.player1.dead)
   {
      _parent.player1.buff(b,p);
   }
   if(!_parent.player2.dead)
   {
      _parent.player2.buff(b,p);
   }
   if(!_parent.player3.dead)
   {
      _parent.player3.buff(b,p);
   }
}
function debuffAll(b, p)
{
   a = 0;
   while(a < _parent.foes.length)
   {
      if(!_parent.foes[a].dead)
      {
         _parent.foes[a].debuff(b,p);
      }
      a++;
   }
}
function pos(p, d, r)
{
   if(r == undefined)
   {
      r = 2;
   }
   _X = ox;
   _Y = oy;
   if(p == 0)
   {
      this.swapDepths(target.graphic.getDepth() + r);
   }
   else
   {
      this.swapDepths(1000);
   }
   if(p == 0)
   {
      this._x = target.getX(d) - this.spellcenter._x;
      this._y = target.getY(d) - this.spellcenter._y;
   }
}
function getXY(type)
{
   if(type == 0)
   {
      _X = 0;
      _Y = 0;
   }
   else
   {
      _X = _root.X() + 80;
      _Y = _root.Y() - 120;
   }
}
ox = _X;
oy = _Y;
